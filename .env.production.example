# CVLab — Production Environment Variables
# Copy to .env.production and fill in ALL values before deploying
# Never commit this file with real values

# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_NAME=CVLab
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=                         # openssl rand -hex 32

# ── Database ───────────────────────────────────────────────────────────────
# If using managed DB (RDS, Supabase etc), set this to external URL
# If using docker-compose postgres, set: postgresql+asyncpg://cvlab:PASSWORD@postgres:5432/cvlab
DATABASE_URL=postgresql+asyncpg://cvlab:CHANGE_ME@postgres:5432/cvlab
POSTGRES_PASSWORD=                  # strong random password

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Storage (AWS S3) ───────────────────────────────────────────────────────
# Leave S3_ENDPOINT_URL blank for real AWS S3
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=cvlab-production
S3_REGION=me-south-1               # Bahrain — closest to UAE

# ── Claude / Anthropic ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-opus-4-6

# ── Retrieval ─────────────────────────────────────────────────────────────
SERPER_API_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (SMTP) ──────────────────────────────────────────────────────────
# Recommended: Resend or Postmark for transactional email
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_...
SMTP_FROM=noreply@cvlab.co
SMTP_FROM_NAME=CVLab
APP_BASE_URL=https://cvlab.co

# ── Frontend / CORS ───────────────────────────────────────────────────────
FRONTEND_URL=https://cvlab.co
ALLOWED_ORIGINS=https://cvlab.co,https://www.cvlab.co

# ── Sentry ────────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT=production
