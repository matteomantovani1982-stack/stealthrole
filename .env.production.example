# CVLab — Production Environment Variables
# Copy to .env.production and fill in ALL values before deploying
# Never commit this file with real values

# ── App ────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_NAME=CVLab
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=                         # openssl rand -hex 32

# ── Database ───────────────────────────────────────────────────────────────
# If using managed DB (RDS, Supabase etc), set this to external URL
# If using docker-compose postgres, set: postgresql+asyncpg://cvlab:PASSWORD@postgres:5432/cvlab
DATABASE_URL=postgresql+asyncpg://cvlab:CHANGE_ME@postgres:5432/cvlab
DATABASE_POOL_SIZE=10               # connections per worker (default 10)
DATABASE_MAX_OVERFLOW=10            # extra connections under load (default 10)
POSTGRES_PASSWORD=                  # strong random password

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Storage (AWS S3) ───────────────────────────────────────────────────────
# Leave S3_ENDPOINT_URL blank for real AWS S3
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=cvlab-production
S3_REGION=me-south-1               # Bahrain — closest to UAE

# ── Claude / Anthropic ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MAX_TOKENS=8192
DEMO_MODE=false                     # true = mock LLM responses, no API billing
ENABLE_LINKEDIN_MSG_CLASSIFY=false

# ── Retrieval ─────────────────────────────────────────────────────────────
SERPER_API_KEY=
NEXT_PUBLIC_API_URL=https://api.cvlab.co

# ── Job APIs (Optional) ────────────────────────────────────────────────────
# Adzuna: free at https://developer.adzuna.com (250 calls/month free)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# JSearch via RapidAPI: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free tier: 200 calls/month
JSEARCH_API_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_UNLIMITED_MONTHLY=price_...
STRIPE_PRICE_UNLIMITED_ANNUAL=price_...

# ── Email (SMTP) ──────────────────────────────────────────────────────────
# Recommended: Resend or Postmark for transactional email
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_...
SMTP_FROM=noreply@cvlab.co
SMTP_FROM_NAME=CVLab
SMTP_USE_TLS=true
APP_BASE_URL=https://cvlab.co

# ── Frontend / CORS ───────────────────────────────────────────────────────
FRONTEND_URL=https://cvlab.co
ALLOWED_ORIGINS=https://stealthrole.com,https://www.stealthrole.com,https://www.linkedin.com

# ── Sentry ────────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ── Email Integration (Gmail / Outlook OAuth) ──────────────────────────────
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Encryption key for stored OAuth tokens (Fernet) — generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_TOKEN_ENCRYPTION_KEY=

# ── Hidden Market Engine (Phase 2) ──────────────────────────────────────────
# Crunchbase: https://data.crunchbase.com/docs (Basic API)
CRUNCHBASE_API_KEY=
# Magnitt: MENA startup intelligence (https://magnitt.com/api)
MAGNITT_API_KEY=
