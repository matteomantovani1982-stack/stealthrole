# CVLab Frontend Environment Variables
# Copy to .env.local and fill in values

# Backend API URL — leave empty to use Vite proxy (development)
VITE_API_URL=

# For production, point at your deployed backend:
# VITE_API_URL=https://api.cvlab.co

# Sentry (optional — leave blank to disable error monitoring)
VITE_SENTRY_DSN=
VITE_APP_ENV=production
VITE_APP_VERSION=1.0.0
