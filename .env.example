# ── Application ───────────────────────────────────────────
APP_ENV=development
APP_NAME=CVLab
APP_VERSION=0.1.0
DEBUG=false
# Demo mode: returns fake LLM responses without hitting Claude API
# Set to true for testing/OpenClaw — set to false for real usage
DEMO_MODE=true
# In APP_ENV=development, all Anthropic calls (packs, profile import, etc.) are skipped
# unless you set:
# FORCE_ANTHROPIC_API=true
# Legacy alias: FORCE_ANTHROPIC_PROFILE_IMPORT=true still forces profile-specific real calls only;
# FORCE_ANTHROPIC_API affects packs + tailoring + ClaudeClient.

# ── Security ──────────────────────────────────────────────
# A random string — this default is fine for local testing
SECRET_KEY=local-dev-secret-key-change-this-before-deploying-xx

# ── Database (pre-filled for local Docker) ────────────────
DATABASE_URL=postgresql+asyncpg://careeros:careeros@postgres:5432/careeros

# ── Redis (pre-filled for local Docker) ──────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── S3 Storage (pre-filled — uses local MinIO) ────────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=careeros
S3_REGION=us-east-1

# ── FILL THESE IN ─────────────────────────────────────────
ANTHROPIC_API_KEY=PASTE_YOUR_ANTHROPIC_KEY_HERE
SERPER_API_KEY=PASTE_YOUR_SERPER_KEY_HERE

# ── Job APIs (Optional — Sprint Q) ────────────────────────
# Adzuna: free at https://developer.adzuna.com (250 calls/month free)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# JSearch via RapidAPI: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free tier: 200 calls/month
JSEARCH_API_KEY=

# ── Claude model ──────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=8192
# LinkedIn message classification — requires LLM credits.
# Set to true only when the /inbox feature is ready.
ENABLE_LINKEDIN_MSG_CLASSIFY=false

# ── Stripe (leave as-is for local — billing won't work but everything else will)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ── Email (leave blank for local — emails just won't send)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@cvlab.co
SMTP_FROM_NAME=CVLab
SMTP_USE_TLS=true
APP_BASE_URL=http://localhost:3000

# ── Hidden Market Engine (Phase 2) ──────────────────────────
# Crunchbase: https://data.crunchbase.com/docs (Basic API)
CRUNCHBASE_API_KEY=
# Magnitt: MENA startup intelligence (https://magnitt.com/api)
MAGNITT_API_KEY=

# ── Email Integration (Gmail / Outlook OAuth) ──────────────
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Encryption key for stored OAuth tokens (Fernet) — generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_TOKEN_ENCRYPTION_KEY=

# ── Frontend URL ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
